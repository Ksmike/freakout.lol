// ─── Projects ────────────────────────────────────────────────────────────────

enum ProjectStatus {
    DRAFT
    IN_PROGRESS
    REVIEWED
    COMPLETE
    REJECTED
}

model Project {
    id        String        @id @default(cuid())
    name      String
    status    ProjectStatus @default(DRAFT)
    userId    String
    firmId    String
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt

    user                             User                              @relation(fields: [userId], references: [id], onDelete: Cascade)
    firm                             Firm                              @relation(fields: [firmId], references: [id], onDelete: Cascade)
    documents                        ProjectDocument[]
    diligenceJobs                    DiligenceJob[]
    diligenceArtifacts               DiligenceArtifact[]
    diligenceFindings                DiligenceFinding[]
    diligenceClaims                  DiligenceClaim[]
    diligenceEntities                DiligenceEntity[]
    diligenceContradictions          DiligenceContradiction[]
    diligenceChunks                  DiligenceChunk[]
    diligenceQuestionAnswers         DiligenceQuestionAnswer[]
    diligenceEvidenceGaps            DiligenceEvidenceGap[]
    diligenceOpenQuestions           DiligenceOpenQuestion[]
    diligenceDocumentClassifications DiligenceDocumentClassification[]
    auditLogs                        AuditLog[]
    assistanceGoal                   AssistanceGoal?
    evidenceMappings                 EvidenceMapping[]

    @@index([userId])
    @@index([firmId, createdAt])
    @@index([firmId, status])
}
